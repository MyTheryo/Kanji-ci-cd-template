default_platform(:ios)

WORKSPACE = "App.xcworkspace"
PROJECT = "App.xcodeproj"
SCHEME = "App"

before_all do
  setup_ci if ENV["CI"]
end

platform :ios do

  # ==========================================
  # Code Signing
  # ==========================================

  desc "Sync certificates"
  lane :sync_certs do |options|
    match(
      type: options[:type] || "appstore",
      readonly: is_ci
    )
  end

  # ==========================================
  # Linting
  # ==========================================

  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      strict: true,
      raise_if_swiftlint_error: true
    )
  end

  # ==========================================
  # Testing
  # ==========================================

  desc "Run tests"
  lane :test do
    run_tests(
      workspace: WORKSPACE,
      scheme: SCHEME,
      device: "iPhone 15",
      clean: true,
      code_coverage: true
    )
  end

  # ==========================================
  # Building
  # ==========================================

  desc "Build for testing (no signing)"
  lane :build_for_testing do
    xcodebuild(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      xcargs: "CODE_SIGNING_ALLOWED=NO build"
    )
  end

  desc "Build for release"
  lane :build_release do |options|
    build_number = options[:build_number] || Time.now.strftime("%Y%m%d%H%M")

    sync_certs(type: "appstore")

    increment_build_number(
      build_number: build_number,
      xcodeproj: PROJECT
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "App.ipa"
    )
  end

  # ==========================================
  # Deployment
  # ==========================================

  desc "Upload to TestFlight"
  lane :upload_testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload to App Store"
  lane :upload_appstore do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end

  # ==========================================
  # Combined Lanes
  # ==========================================

  desc "Deploy to TestFlight"
  lane :deploy_testflight do |options|
    build_release(build_number: options[:build_number])
    upload_testflight
  end

  desc "Deploy to App Store"
  lane :deploy_appstore do |options|
    build_release(build_number: options[:build_number])
    upload_appstore
  end

end
